# ── DashScope / VLM API ──────────────────────────────────────────
DASHSCOPE_API_KEY=sk-your-api-key-here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3-vl-plus

# ── YOLO Pose Detector ───────────────────────────────────────────
OMPOSE_YOLO_MODEL_PATH=assets/models/yolo26n-pose.pt
OMPOSE_YOLO_IMGSZ=320
OMPOSE_YOLO_CONF=0.25
OMPOSE_YOLO_TORCH_THREADS=4

# ── Streaming / WebSocket ────────────────────────────────────────
OMPOSE_STREAM_MAX_FPS=12
OMPOSE_STREAM_RETURN_OVERLAY=false
OMPOSE_MAX_STREAMS_PER_PROCESS=1

# ── CORS ─────────────────────────────────────────────────────────
OMPOSE_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://0.0.0.0:5173
OMPOSE_CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|0\.0\.0\.0|10\.\d+\.\d+\.\d+|172\.(1[6-9]|2\d|3[01])\.\d+\.\d+|192\.168\.\d+\.\d+):\d+$
